# Basic Auth for the whole app.
APP_USERNAME=your_username
APP_PASSWORD=your_password

# Google Sheets service account access.
GOOGLE_SHEET_ID=your_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@your_project.iam.gserviceaccount.com

# Vercel can store this as escaped newlines or as a real multiline value.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"

# Google Sheet tab names used by the app.
GOOGLE_SHEET_DAILY_LOG_TAB=food_logs
GOOGLE_SHEET_DAILY_STATUS_TAB=daily_status
GOOGLE_SHEET_COMMON_FOODS_TAB=foods
GOOGLE_SHEET_MEAL_PREPS_TAB=meal_preps
GOOGLE_SHEET_MEAL_PREP_ITEMS_TAB=meal_prep_items
GOOGLE_SHEET_SETTINGS_TAB=settings
